<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
 ============================================================
  [EX] MyBatis XML 매퍼 실습 (스켈레톤) — 상품(Product) 편
 ============================================================
  - namespace 는 매퍼 인터페이스의 전체 경로와 일치해야 한다.
  - 각 <select> 의 id 는 인터페이스 메서드명과 일치해야 한다.
  - 참고 : 같은 폴더의 MemoMapper.xml (완성 예시)
 ============================================================
-->
<mapper namespace="com.example.demo.Domain.Common.Mapper.ProductMapper">

    <!--
      [EX04] 전체 조회
      - resultType 은 ProductDTO 의 전체 경로
      [TODO] 아래 select 본문(SQL)을 작성하세요.
    -->
    <select id="selectAllXML" resultType="com.example.demo.Domain.Common.Dtos.ProductDTO">
        <!-- TODO: select * from tbl_product -->
        SELECT * FROM tbl_product
    </select>


    <!--
      [EX05] 동적 SQL 검색
      - parameterType : java.util.Map  (keys: keyword, minStock)
      - keyword 가 있으면 pname LIKE '%keyword%'
      - minStock 이 있으면 stock >= #{minStock}
      - <where> 와 <if> 를 사용해, 조건이 없으면 전체 조회가 되도록 한다.

      [TODO] 아래 골격의 주석을 풀고 채우세요.
    -->
    <select id="searchXML" resultType="java.util.Map" parameterType="java.util.Map">
        select * from tbl_product

        <where>
            <if test="keyword != null and keyword != ''">
                pname like concat('%', #{keyword}, '%')
            </if>
            <if test="minStock != null">
                and stock &gt;= #{minStock}
            </if>
        </where>

    </select>

</mapper>
